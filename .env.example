# Optional: use when you add a backend API.
# Copy to .env and set values. .env is gitignored.

# Base URL of your API (e.g. Vercel serverless or external backend)
# VITE_API_URL=https://your-app.vercel.app/api

# If you move admin credentials to the server, you might add:
# (Do not commit real secrets to GitHub; set them in Vercel Project Settings → Environment Variables)
# VITE_APP_NAME=MSC & CTSB SPORTS
